{
  "manifest_version": 3,
  "name": "Super Gemini GUI",
  "version": "1.1",
  "description": "Folders, Search, and Tags for the official Gemini website.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://gemini.google.com/app/*"
      ],
      "js": ["content.js"],
      "css": ["inject.css"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": ["https://gemini.google.com/*"]
}
